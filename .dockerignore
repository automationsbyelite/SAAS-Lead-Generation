# ─── Version Control ────────────────────────────────────────
.git
.gitignore

# ─── Docker files (no circular inclusion) ───────────────────
Dockerfile
docker-compose*.yml
.dockerignore

# ─── Environment files (never bake secrets into images) ──────
.env
.env.*
!.env.example

# ─── Node Modules (Docker installs its own inside container) ─
node_modules
**/node_modules

# ─── Build Artifacts ─────────────────────────────────────────
dist
**/dist
.next
**/.next

# ─── Logs ───────────────────────────────────────────────────
*.log
npm-debug.log*
logs/

# ─── OS / IDE ────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode
.idea

# ─── Tests ───────────────────────────────────────────────────
**/*.spec.ts
**/*.test.ts
coverage/

# ─── Docs that don't need to be in the container ─────────────
*.md
!apps/backend/src/**/*.md
