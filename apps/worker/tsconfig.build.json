{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2021",
        "outDir": "./dist",
        "rootDir": "../../",
        "strict": false,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "baseUrl": ".",
        "paths": {
            "@shared/*": [
                "../../packages/shared/*"
            ],
            "@backend/*": [
                "../../apps/backend/src/*"
            ],
            "@ai-call/*": [
                "../../packages/ai-call/src/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "../../packages/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}