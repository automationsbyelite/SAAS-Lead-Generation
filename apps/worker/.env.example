# ==========================================
# WORKER ENVIRONMENT VARIABLES
# ==========================================
# Replace these placeholder values with your real API keys
# to enable the True Third-Party Integrations.

# 1. Scraper Configuration (Tiered Engine)
# FREE Tier: SerpApi (Get your key at https://serpapi.com/manage-api-key)
SERPAPI_KEY=YOUR_SERPAPI_KEY_HERE

# PRO Tier: Oxylabs Web Scraper (https://dashboard.oxylabs.io/)
OXYLABS_USERNAME=YOUR_OXYLABS_USERNAME
OXYLABS_PASSWORD=YOUR_OXYLABS_PASSWORD

# 2. VAPI Configuration (AI Voice Calling)
# Get your private key at: https://dashboard.vapi.ai/
VAPI_API_KEY=YOUR_VAPI_API_KEY
VAPI_URL=https://api.vapi.ai/call
# Your provisioned phone number UUID (Required for outbound)
VAPI_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
# Your default Assistant UUID (If not injecting custom per-campaign)
VAPI_ASSISTANT_ID=YOUR_ASSISTANT_ID

# 3. Email Module Configuration (SMTP)
# Use your preferred provider (Gmail, SendGrid, Amazon SES, Mailgun, Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=YOUR_SMTP_USER
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM_NAME="ReachStack"
SMTP_FROM_EMAIL=your-email@example.com

# ------------------------------------------
# PostgreSQL Database Connection
# Keep these as default for local Docker development
# ------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=saas

# ------------------------------------------
# Redis / BullMQ Connection
# Keep these as default for local Docker development
# ------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ------------------------------------------
# Groq AI (Email Generation)
# Get your key at: https://console.groq.com/keys
# ------------------------------------------
GROQ_API_KEY=YOUR_GROQ_API_KEY
