    "item": [
        {
            "name": "1. Authentication",
            "item": [
                {
                    "name": "1. Login (Super Admin)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const responseJson = pm.response.json();",
                                    "if (responseJson.access_token) {",
                                    "    pm.collectionVariables.set(\"jwt_token\", responseJson.access_token);",
                                    "    pm.collectionVariables.set(\"tenantId\", responseJson.user.tenantId);",
                                    "    console.log(\"Saved JWT & Tenant ID to collection variables\");",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"master@system.com\",\n  \"password\": \"admin123\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        }
                    },
                    "response": []
                },
